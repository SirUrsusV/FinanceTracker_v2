@model FinanceTracker.DTO.DashboardDto
@{
    ViewData["Title"] = "Дашборд";
}
<div class="container py-4">
    <div class="mb-4">
        <h1 class="display-5 fw-semibold">Ваш финансовый дашборд</h1>
        <p class="text-muted">Обзор доходов и расходов за текущий месяц</p>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card stat-card border-success">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6>Доходы</h6><h3 class="text-success">@Model.TotalIncome.ToString("C")</h3></div>
                    <i class="bi bi-arrow-up-short fs-1 text-success opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-danger">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6>Расходы</h6><h3 class="text-danger">@Model.TotalExpense.ToString("C")</h3></div>
                    <i class="bi bi-arrow-down-short fs-1 text-danger opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-primary">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6>Баланс</h6><h3 class="text-primary">@Model.TotalBalance.ToString("C")</h3></div>
                    <i class="bi bi-wallet2 fs-1 text-primary opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Последние транзакции</h5>
                    <a href="/Transactions/Index" class="btn btn-sm btn-outline-secondary">Все</a>
                </div>
                <div class="card-body">
                    @if (Model.RecentTransactions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Дата</th>
                                        <th>Описание</th>
                                        <th>Категория</th>
                                        <th>Сумма</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.RecentTransactions.Take(5))
                                    {
                                        <tr>
                                            <td>@t.Date.ToString("dd.MM.yyyy")</td>
                                            <td>@t.Description</td>
                                            <td><span class="badge" style="background-color:@t.CategoryColor">@t.CategoryIcon @t.CategoryName</span></td>
                                            <td class="@(t.Type == "Income" ? "text-success fw-semibold" : "text-danger fw-semibold")">@(t.Type == "Income" ? "+" : "-") @t.Amount.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">Нет транзакций. Добавьте первую.</p>
                    }
                    <div class="text-center mt-3">
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
                            <i class="bi bi-plus-lg me-1"></i>Добавить транзакцию
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0"><h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Расходы по категориям</h5></div>
                <div class="card-body">
                    @if (Model.ExpensesByCategory.Any())
                    {
                        @foreach (var cat in Model.ExpensesByCategory)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span><span class="fs-5">@cat.CategoryIcon</span> @cat.CategoryName</span>
                                    <span class="fw-semibold">@cat.TotalAmount.ToString("C")</span>
                                </div>
                                <div class="progress" style="height:8px"><div class="progress-bar" style="width:@cat.Percentage%; background-color:@cat.CategoryColor"></div></div>
                                <small class="text-muted">@cat.Percentage% от расходов</small>
                            </div>
                        }
                    }
                    else { <p class="text-muted text-center py-3">Нет данных о расходах.</p> }
                </div>
            </div>
        </div>
    </div>

    @if (Model.MonthlyData.Any())
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-white border-0 pt-3 pb-0"><h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Динамика доходов и расходов</h5></div>
                    <div class="card-body"><canvas id="monthlyChart" width="100%" height="50%"></canvas></div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Модальное окно создания транзакции -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="createModalContent">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var monthlyData = @Html.Raw(Json.Serialize(Model.MonthlyData));
        if (monthlyData && monthlyData.length) {
            var ctx = document.getElementById('monthlyChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: monthlyData.map(m => m.month),
                    datasets: [
                        { label: 'Доходы', data: monthlyData.map(m => m.income), borderColor: 'rgb(25,135,84)', backgroundColor: 'rgba(25,135,84,0.1)', tension: 0.3, fill: true },
                        { label: 'Расходы', data: monthlyData.map(m => m.expense), borderColor: 'rgb(220,53,69)', backgroundColor: 'rgba(220,53,69,0.1)', tension: 0.3, fill: true }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'top' } }, scales: { y: { ticks: { callback: (v) => new Intl.NumberFormat('ru-RU',{style:'currency',currency:'RUB',minimumFractionDigits:0}).format(v) } } } }
            });
        }

        // AJAX загрузка формы создания транзакции в модальное окно
        $('#createModal').on('show.bs.modal', function () {
            $('#createModalContent').load('/Transactions/CreateModal');
        });

        // Обработка отправки формы (AJAX)
        $(document).on('submit', '#createTransactionForm', function (e) {
            e.preventDefault();
            var form = $(this);
            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        $('#createModal').modal('hide');
                        location.reload(); // обновляем дашборд после добавления
                    } else {
                        $('#createModalContent').html(response);
                        $.validator.unobtrusive.parse("#createTransactionForm");
                    }
                },
                error: function () {
                    alert('Ошибка сохранения транзакции.');
                }
            });
        });

        // Сброс содержимого при закрытии модального окна
        $('#createModal').on('hidden.bs.modal', function () {
            $('#createModalContent').html('<div class="text-center p-5"><div class="spinner-border text-primary" role="status"></div></div>');
        });
    </script>
}