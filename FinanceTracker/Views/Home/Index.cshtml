@model FinanceTracker.DTO.DashboardDto
@{
    ViewData["Title"] = "Дашборд";
}
<div class="container py-4">
    <div class="mb-4">
        <h1 class="display-5 fw-semibold">Ваш финансовый дашборд</h1>
        <p class="text-muted">Обзор доходов и расходов за текущий месяц</p>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card stat-card border-success">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6>Доходы</h6><h3 class="text-success">@Model.TotalIncome.ToString("C")</h3></div>
                    <i class="bi bi-arrow-up-short fs-1 text-success opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-danger">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6>Расходы</h6><h3 class="text-danger">@Model.TotalExpense.ToString("C")</h3></div>
                    <i class="bi bi-arrow-down-short fs-1 text-danger opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-primary">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6>Баланс</h6><h3 class="text-primary">@Model.TotalBalance.ToString("C")</h3></div>
                    <i class="bi bi-wallet2 fs-1 text-primary opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Последние транзакции</h5>
                    <a href="/Transactions/" class="btn btn-sm btn-outline-secondary">Все</a>
                </div>
                <div class="card-body">
                    @if (Model.RecentTransactions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Дата</th>
                                        <th>Описание</th>
                                        <th>Категория</th>
                                        <th>Сумма</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.RecentTransactions.Take(5))
                                    {
                                        <tr>
                                            <td>@t.Date.ToString("dd.MM.yyyy")</td>
                                            <td>@t.Description</td>
                                            <td><span class="badge" style="background-color:@t.CategoryColor">@t.CategoryIcon @t.CategoryName</span></td>
                                            <td class="@(t.Type == "Income" ? "text-success fw-semibold" : "text-danger fw-semibold")">@(t.Type == "Income" ? "+" : "-") @t.Amount.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">Нет транзакций. Добавьте первую.</p>
                    }
                    <div class="text-center mt-3">
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
                            <i class="bi bi-plus-lg me-1"></i>Добавить транзакцию
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0"><h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Расходы по категориям</h5></div>
                <div class="card-body">
                    @if (Model.ExpensesByCategory.Any())
                    {
                        @foreach (var cat in Model.ExpensesByCategory)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span><span class="fs-5">@cat.CategoryIcon</span> @cat.CategoryName</span>
                                    <span class="fw-semibold">@cat.TotalAmount.ToString("C")</span>
                                </div>
                                <div class="progress" style="height:8px"><div class="progress-bar" style="width:@cat.Percentage%; background-color:@cat.CategoryColor"></div></div>
                                <small class="text-muted">@cat.Percentage% от расходов</small>
                            </div>
                        }
                    }
                    else { <p class="text-muted text-center py-3">Нет данных о расходах.</p> }
                </div>
            </div>
        </div>
    </div>

    @if (Model.MonthlyData.Any())
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Динамика доходов и расходов</h5>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary chart-period" data-months="3">3 месяца</button>
                            <button type="button" class="btn btn-outline-secondary chart-period active" data-months="6">6 месяцев</button>
                            <button type="button" class="btn btn-outline-secondary chart-period" data-months="12">1 год</button>
                        </div>
                    </div>
                    <div class="card-body" style="height: 1%; width: 100%">
                        <canvas id="monthlyChart" width="100%"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Модальное окно создания транзакции -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="createModalContent">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let chart;
        // Функция загрузки данных и перерисовки графика
        function loadChartData(months) {
            $.ajax({
                url: '/Home/GetChartData',
                type: 'GET',
                data: { months: months },
                success: function(data) {
                    if (chart) {
                        chart.destroy();
                    }
                    const ctx = document.getElementById('monthlyChart').getContext('2d');
                    chart = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.map(m => m.month),
                            datasets: [
                                {
                                    label: 'Доходы',
                                    data: data.map(m => m.income),
                                    borderColor: 'rgb(25, 135, 84)',
                                    backgroundColor: 'rgba(25, 135, 84, 0.1)',
                                    tension: 0.3,
                                    fill: true,
                                    pointBackgroundColor: 'rgb(25, 135, 84)'
                                },
                                {
                                    label: 'Расходы',
                                    data: data.map(m => m.expense),
                                    borderColor: 'rgb(220, 53, 69)',
                                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                                    tension: 0.3,
                                    fill: true,
                                    pointBackgroundColor: 'rgb(220, 53, 69)'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: { position: 'top' },
                                tooltip: { callbacks: { label: (ctx) => `${ctx.dataset.label}: ${new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB' }).format(ctx.raw)}` } }
                            },
                            scales: {
                                y: {
                                    ticks: { callback: (value) => new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB', minimumFractionDigits: 0 }).format(value) }
                                }
                            }
                        }
                    });
                },
                error: function() {
                    alert('Ошибка загрузки данных для графика');
                }
            });
        }

        $(document).ready(function() {
            // Загрузка начальных данных (6 месяцев)
            loadChartData(6);

            // Обработка нажатия на кнопки периода
            $('.chart-period').click(function() {
                $('.chart-period').removeClass('active');
                $(this).addClass('active');
                const months = $(this).data('months');
                loadChartData(months);
            });
        });
    </script>
}