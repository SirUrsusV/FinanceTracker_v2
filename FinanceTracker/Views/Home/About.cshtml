@{
    ViewData["Title"] = "О проекте";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h1 class="display-4">Финансовый трекер</h1>
                    <p class="lead">Простое и удобное приложение для учёта личных финансов.</p>
                    <hr />
                    <h3>Возможности</h3>
                    <ul>
                        <li>Добавление доходов и расходов</li>
                        <li>Категории с цветами и иконками</li>
                        <li>Аналитика и графики</li>
                        <li>Фильтрация транзакций</li>
                        <li>Безопасное хранение данных (каждый пользователь видит только свои записи)</li>
                    </ul>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="text-center mt-4">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-primary" style="display:inline; cursor:pointer;">Выйти</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mt-4">
                            <a href="/Account/Login" class="btn btn-primary">Войти</a>
                            <a href="/Account/Register" class="btn btn-outline-secondary ms-2">Зарегистрироваться</a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>