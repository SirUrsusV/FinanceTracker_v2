@model List<FinanceTracker.DTO.TransactionDto>
@{
    ViewData["Title"] = "Транзакции";
}
<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-semibold"><i class="bi bi-arrow-left-right me-2"></i>Транзакции</h1>
        <div>
            <button type="button" class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#createModal">
                <i class="bi bi-plus-lg me-1"></i>Добавить транзакцию
            </button>
            <a href="#" id="exportExcelBtn" class="btn btn-info">
                <i class="bi bi-file-excel me-1"></i>Экспорт в Excel
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Фильтры -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3"><i class="bi bi-funnel me-2"></i>Фильтры</div>
        <div class="card-body">
            <form method="get" class="row g-3" id="filterForm">
                <div class="col-md-3 col-sm-6">
                    <label class="form-label">Тип</label>
                    <select name="type" id="filterType" class="form-select">
                        <option value="">Все</option>
                        <option value="Income" selected="@(ViewBag.CurrentType == "Income")">Доходы</option>
                        <option value="Expense" selected="@(ViewBag.CurrentType == "Expense")">Расходы</option>
                    </select>
                </div>
                <div class="col-md-3 col-sm-6">
                    <label class="form-label">Категория</label>
                    <select name="categoryId" id="filterCategoryId" class="form-select">
                        <option value="">Все</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat.Id" selected="@(ViewBag.CurrentCategoryId == cat.Id)" data-type="@cat.DefaultType">@cat.Icon @cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label">С даты</label>
                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label">По дату</label>
                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Применить</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Статистика -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card bg-success bg-opacity-10 border-success">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6 class="text-success-emphasis">Доходы</h6><h3 class="text-success">@ViewBag.TotalIncome.ToString("C")</h3></div>
                    <i class="bi bi-arrow-up-short fs-1 text-success opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger bg-opacity-10 border-danger">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6 class="text-danger-emphasis">Расходы</h6><h3 class="text-danger">@ViewBag.TotalExpense.ToString("C")</h3></div>
                    <i class="bi bi-arrow-down-short fs-1 text-danger opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-primary bg-opacity-10 border-primary">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div><h6 class="text-primary-emphasis">Баланс</h6><h3 class="text-primary">@ViewBag.Balance.ToString("C")</h3></div>
                    <i class="bi bi-wallet2 fs-1 text-primary opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Таблица транзакций -->
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3"><i class="bi bi-table me-2"></i>Список транзакций</div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Дата</th>
                                <th>Описание</th>
                                <th>Категория</th>
                                <th>Сумма</th>
                                <th>Тип</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd.MM.yyyy")</td>
                                    <td>@item.Description</td>
                                    <td><span class="badge" style="background-color:@item.CategoryColor">@item.CategoryIcon @item.CategoryName</span></td>
                                    <td class="@(item.Type == "Income" ? "text-success fw-semibold" : "text-danger fw-semibold")">@item.Amount.ToString("C")</td>
                                    <td>
                                        @if (item.Type == "Income")
                                        {
                                            <span class="badge bg-success">Доход</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Расход</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="btn btn-outline-primary edit-btn" data-id="@item.Id" title="Редактировать"><i class="bi bi-pencil-square"></i></button>
                                            <button type="button" class="btn btn-outline-danger delete-btn" data-id="@item.Id" title="Удалить"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <p class="mt-3 text-muted">Нет транзакций, удовлетворяющих условиям фильтра.</p>
                    <button type="button" class="btn btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#createModal">Добавить транзакцию</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Модальные окна -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="createModalContent">
            <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="editModalContent">
            <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="deleteModalContent">
            <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Фильтрация категорий по типу в фильтрах
        var allCategoriesFilter = @Html.Raw(Json.Serialize(ViewBag.Categories));
        function filterCategoriesByType(selectedType) {
            var categorySelect = document.getElementById('filterCategoryId');
            var currentValue = categorySelect.value;
            categorySelect.innerHTML = '<option value="">Все</option>';
            if (!selectedType) {
                allCategoriesFilter.forEach(function(cat) {
                    var option = document.createElement('option');
                    option.value = cat.id;
                    option.text = cat.icon + ' ' + cat.name;
                    if (currentValue && currentValue == cat.id) option.selected = true;
                    categorySelect.appendChild(option);
                });
            } else {
                var filtered = allCategoriesFilter.filter(function(cat) {
                    return !cat.defaultType || cat.defaultType === selectedType;
                });
                filtered.forEach(function(cat) {
                    var option = document.createElement('option');
                    option.value = cat.id;
                    option.text = cat.icon + ' ' + cat.name;
                    if (currentValue && currentValue == cat.id) option.selected = true;
                    categorySelect.appendChild(option);
                });
            }
        }
        var filterTypeSelect = document.getElementById('filterType');
        if (filterTypeSelect) {
            filterTypeSelect.addEventListener('change', function() { filterCategoriesByType(this.value); });
            filterCategoriesByType(filterTypeSelect.value);
        }

        // Экспорт в Excel с текущими фильтрами
        $('#exportExcelBtn').click(function(e) {
            e.preventDefault();
            var formData = $('#filterForm').serialize();
            window.location.href = '/Transactions/ExportToExcel?' + formData;
        });

        // Модальное окно создания
        $('#createModal').on('show.bs.modal', function () {
            $('#createModalContent').load('/Transactions/CreateModal');
        });
        $(document).on('submit', '#createTransactionForm', function (e) {
            e.preventDefault();
            var form = $(this);
            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        $('#createModal').modal('hide');
                        location.reload();
                    } else {
                        $('#createModalContent').html(response);
                        $.validator.unobtrusive.parse("#createTransactionForm");
                        initCategoryFilterInModal();
                    }
                },
                error: function () { alert('Ошибка сохранения.'); }
            });
        });
        $('#createModal').on('hidden.bs.modal', function () {
            $('#createModalContent').html('<div class="text-center p-5"><div class="spinner-border text-primary"></div></div>');
        });

        // Модальное окно редактирования
        $(document).on('click', '.edit-btn', function () {
            var id = $(this).data('id');
            $('#editModalContent').load('/Transactions/EditModal/' + id);
            $('#editModal').modal('show');
        });
        $(document).on('submit', '#editTransactionForm', function (e) {
            e.preventDefault();
            var form = $(this);
            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        $('#editModal').modal('hide');
                        location.reload();
                    } else {
                        $('#editModalContent').html(response);
                        $.validator.unobtrusive.parse("#editTransactionForm");
                        initCategoryFilterInEditModal();
                    }
                },
                error: function () { alert('Ошибка обновления.'); }
            });
        });
        $('#editModal').on('hidden.bs.modal', function () {
            $('#editModalContent').html('<div class="text-center p-5"><div class="spinner-border text-primary"></div></div>');
        });

        // Модальное окно удаления
        $(document).on('click', '.delete-btn', function () {
            var id = $(this).data('id');
            $('#deleteModalContent').load('/Transactions/DeleteModal/' + id);
            $('#deleteModal').modal('show');
        });
        $(document).on('submit', '#deleteTransactionForm', function (e) {
            e.preventDefault();
            var form = $(this);
            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        $('#deleteModal').modal('hide');
                        location.reload();
                    } else {
                        $('#deleteModalContent').html(response);
                    }
                },
                error: function () { alert('Ошибка удаления.'); }
            });
        });
        $('#deleteModal').on('hidden.bs.modal', function () {
            $('#deleteModalContent').html('<div class="text-center p-5"><div class="spinner-border text-primary"></div></div>');
        });

        function initCategoryFilterInModal() {
            var typeSelect = document.getElementById('TransactionType');
            if (typeSelect && typeof window.filterCategoriesInForm === 'function') {
                window.filterCategoriesInForm();
            }
        }
        function initCategoryFilterInEditModal() {
            var typeSelect = document.getElementById('EditTransactionType');
            if (typeSelect && typeof window.filterCategoriesInEditForm === 'function') {
                window.filterCategoriesInEditForm();
            }
        }
    </script>
}