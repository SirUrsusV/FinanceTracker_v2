@model FinanceTracker.DTO.TransactionDto
@{
    ViewData["Title"] = "Детали транзакции";
}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3"><h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Детали транзакции</h4></div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Дата</dt>
                        <dd class="col-sm-9">@Model.Date.ToString("dd.MM.yyyy")</dd>
                        <dt class="col-sm-3">Описание</dt>
                        <dd class="col-sm-9">@Model.Description</dd>
                        <dt class="col-sm-3">Категория</dt>
                        <dd class="col-sm-9"><span class="badge" style="background-color:@Model.CategoryColor">@Model.CategoryIcon @Model.CategoryName</span></dd>
                        <dt class="col-sm-3">Сумма</dt>
                        <dd class="col-sm-9 fw-bold @(Model.Type == "Income" ? "text-success" : "text-danger")">@Model.Amount.ToString("C")</dd>
                        <dt class="col-sm-3">Тип</dt>
                        <dd class="col-sm-9">@(Model.Type == "Income" ? Html.Raw("<span class=\"badge bg-success\">Доход</span>") : Html.Raw("<span class=\"badge bg-danger\">Расход</span>"))</dd>
                        <dt class="col-sm-3">Создано</dt>
                        <dd class="col-sm-9">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <dt class="col-sm-3">Обновлено</dt>
                            <dd class="col-sm-9">@Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</dd>
 }
                    </dl>
                    <div class="d-flex justify-content-between mt-4"><a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Назад</a><div><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i>Редактировать</a><a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger ms-2"><i class="bi bi-trash me-1"></i>Удалить</a></div></div>
                </div>
            </div>
        </div>
    </div>
</div>