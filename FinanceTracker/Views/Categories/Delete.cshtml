@model FinanceTracker.DTO.CategoryDto
@{
    ViewData["Title"] = "Удалить категорию";
}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-3"><h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Подтверждение удаления</h4></div>
                <div class="card-body">
                    <h5>Вы уверены, что хотите удалить категорию <strong>@Model.Name</strong>?</h5>
                    <hr />
                    <dl class="row">
                        <dt class="col-sm-3">Иконка</dt>
                        <dd class="col-sm-9">@Model.Icon</dd>
                        <dt class="col-sm-3">Название</dt>
                        <dd class="col-sm-9">@Model.Name</dd>
                        <dt class="col-sm-3">Цвет</dt>
                        <dd class="col-sm-9"><span style="background-color:@Model.Color; padding:2px 10px; border-radius:4px;">&nbsp;&nbsp;&nbsp;&nbsp;</span> @Model.Color</dd>
                        <dt class="col-sm-3">Тип</dt>
                        <dd class="col-sm-9"><span class="badge @(Model.DefaultType == "Income" ? "bg-success" : "bg-danger")">@(Model.DefaultType == "Income" ? "Доход" : "Расход")</span></dd>
                    </dl>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between"><a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg me-1"></i>Отмена</a><button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Удалить</button></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>